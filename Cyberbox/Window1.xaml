<Window x:Class="Cyberbox.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cyberbox"
        mc:Ignorable="d"
        Title="Import Settings" Height="450" Width="600">
    <Grid>
        <Button Content="Select show file" HorizontalAlignment="Center" Margin="0,31,0,0" VerticalAlignment="Top" Width="500" Click="ShowFile_Click" Height="20"/>
        <TextBox Name="FileNameTextBox" HorizontalAlignment="Left" Margin="63,84,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120" Height="18"/>
        <TextBlock Name="TextBlock1" HorizontalAlignment="Left" Margin="224,84,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Height="16" Width="54"/>
        <Button Name="Cancel" Content="Cancel" HorizontalAlignment="Left" Margin="491,364,0,0" VerticalAlignment="Top" Click="Cancel_Click" Height="34" Width="80" FontSize="24"/>

    </Grid>
</Window>
