<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cyberbox"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf" x:Class="Cyberbox.MainWindow"
        mc:Ignorable="d"
        Title="Cyberbox" Height="1080" Width="1920" Foreground="White" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" WindowStyle="None">
    <Window.Background>
        <ImageBrush ImageSource="/decoder background.png"/>
    </Window.Background>
    <Grid>
        <Rectangle HorizontalAlignment="Left" Height="35" Margin="28,1023,0,0" VerticalAlignment="Top" Width="706" RadiusX="5.5" RadiusY="5.5" Stroke="Black" Fill="Black"/>
        <TextBlock x:Name="songInfoTextBlock" Text="No Song Playing" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="33,0,0,27" Height="31" Width="777" FontSize="24"/>
        <Rectangle HorizontalAlignment="Center" Height="54" VerticalAlignment="Top" Width="1920" Stroke="Black" Fill="White"/>
        <TextBlock x:Name="Title" HorizontalAlignment="Left" Margin="1666,-2,0,0" TextWrapping="Wrap" Text="Cyberbox" VerticalAlignment="Top" Height="54" Width="166" FontSize="36" Foreground="Black"/>
        <TextBlock x:Name="Version" Margin="1837,-2,0,0" TextWrapping="Wrap" Text="V1.0" VerticalAlignment="Top" FontSize="36" Height="54" Foreground="Black"/>
        <Button x:Name="Quit" Content="Quit" HorizontalAlignment="Left" Margin="450,2,0,0" VerticalAlignment="Top" Height="50" Width="110" ToolTip="Quits the program" FontSize="24" AutomationProperties.Name="Quit" Click="Quit_Click" RenderTransformOrigin="0.505,0.48"/>
        <Button x:Name="BGM" Content="BGM" Margin="303,2,1507,1028" FontSize="24" Click="Button_Click" ToolTip="Enables and disables BGM"/>
        <Button x:Name="File" Content="File" HorizontalAlignment="Left" Margin="10,2,0,0" VerticalAlignment="Top" Height="50" Width="111" FontSize="24" RenderTransformOrigin="0.505,0.48"/>
        <Button x:Name="Edit" Content="Edit" Margin="156,2,1654,1028" FontSize="24"/>
        <Button Content="Export" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="46" Width="200" Height="70" Margin="1661,961,0,0"/>
        <StatusBar Margin="33,601,1218,87"/>
        <ProgressBar HorizontalAlignment="Center" Height="28" Margin="0,532,0,0" VerticalAlignment="Top" Width="1260"/>
    </Grid>
</Window>
