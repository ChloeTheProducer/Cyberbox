<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cyberbox"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf" x:Class="Cyberbox.MainWindow"
        mc:Ignorable="d"
        Title="Cyberbox" Height="960" Width="1280" Foreground="White" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" WindowStyle="None">
    <Window.Background>
        <ImageBrush ImageSource="/decoder background.png"/>
    </Window.Background>
    <Grid>
        <Button x:Name="Quit" Content="Quit" HorizontalAlignment="Left" Margin="1134,878,0,0" VerticalAlignment="Top" Height="50" Width="111" ToolTip="Quits the program" FontSize="24" AutomationProperties.Name="Quit" Click="Quit_Click">
        </Button>
        <MediaElement Height="100" Width="100"/>
        <Button x:Name="BGM" Content="BGM" Margin="1002,878,167,32" FontSize="24" Click="Button_Click" ToolTip="Enables and disables BGM"/>
        <Rectangle HorizontalAlignment="Left" Height="35" Margin="27,905,0,0" VerticalAlignment="Top" Width="706" RadiusX="5.5" RadiusY="5.5" Stroke="Black" Fill="Black"/>
        <TextBlock Name="songInfoTextBlock" Text="No Song Playing" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="33,0,0,26" Height="31" Width="777" FontSize="24"/>
        <TextBlock HorizontalAlignment="Left" Margin="10,0,0,0" TextWrapping="Wrap" Text="Cyberbox" VerticalAlignment="Top" Height="169" Width="422" FontSize="72"/>
        <TextBlock HorizontalAlignment="Left" Margin="1162,0,0,0" TextWrapping="Wrap" Text="V1.0" VerticalAlignment="Top" FontSize="48" Width="158"/>
        <ComboBox HorizontalAlignment="Left" Margin="75,235,0,0" VerticalAlignment="Top" Width="260" Height="22" IsReadOnly="True" FontWeight="Bold">
            <ComboBoxItem Content="Rock afire Explosion" FontFamily="Segoe UI" FontWeight="Bold"/>
            <ComboBoxItem Content="PTT Cybers" FontWeight="Bold"/>
            <ComboBoxItem Content="Modern Cybers" FontWeight="Bold"/>
            <ComboBoxItem Content="CU 3-Stage" FontWeight="Bold"/>
            <ComboBoxItem Content="Rock and Roll Rebellion" FontWeight="Bold"/>
        </ComboBox>
        <TextBlock HorizontalAlignment="Left" Margin="75,174,0,0" TextWrapping="Wrap" Text="Select Encoding:" VerticalAlignment="Top" Height="49" Width="358" FontSize="36"/>
    </Grid>
</Window>
